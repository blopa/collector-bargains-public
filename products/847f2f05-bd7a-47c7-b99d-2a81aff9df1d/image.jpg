.etatooltip-icon { position: relative; display: inline-block; color: #999; border-radius: 50%; padding: 0 0 0 5px; font-size: 12px; cursor: pointer; height: 12px; }
.etatooltip-icon::after { content: ''; visibility: hidden; background-color: #222; color: #fff; border-radius: 5px; padding: 5px; position: absolute; z-index: 1; width: 160px; line-height: 1.5em; bottom: 15px; left: 50%; transform: translateX(-50%); white-space: break-spaces; opacity: 0; transition: opacity 0.3s; }
.etatooltip-icon::before { content: ''; position: absolute; visibility: hidden; bottom: 6px; left: 60%; transform: translateX(-50%); border-width: 5px; border-style: solid; border-color: #222 transparent transparent transparent; opacity: 0; transition: opacity 0.3s; }
.etatooltip-icon:hover::after, .etatooltip-icon:hover::before { visibility: visible; opacity: 0.9; }
.etatooltip::after { content: "Estimated time of arrival, it may change without notice."; }
.woocommerce .posave, .posave { background: #ef3f32; color: #fff; font-size: 80%; font-weight: bold; border-radius: 5px; padding: 3px 5px; }
