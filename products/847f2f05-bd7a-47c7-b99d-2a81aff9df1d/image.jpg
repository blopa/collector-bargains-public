/* Virtual Warehouse */
/* old style #save-to-warehouse { margin-bottom: 0; border-top: 2px solid #222; padding-top: 15px; } */
#save-to-warehouse { border-radius: 10px; box-shadow: 0 5px 10px 0 rgba(0,0,0,.1), 0 2px 4px 0 rgba(0,0,0,.05); background: #fff; padding: 10px; margin-top: 0; margin-bottom: 10px; }
#save-to-warehouse label input { margin-left: 8px; }
#save-to-warehouse label span:before { content: "\f1b3"; font: normal normal normal 14px/1 FontAwesome; margin: 0 5px 0 2px; }
#save-to-warehouse label span { font-size: 20px; font-weight: bold; }
#save-to-warehouse span i.fas { font: normal normal normal 14px/1 FontAwesome; font-size: 20px; }
/* Checkbox style */
#save-to-warehouse { position: relative; }
#save-to-warehouse label:hover { cursor: pointer; }
#save-to-warehouse input { position: absolute; z-index: -1; opacity: 0; }
#save-to-warehouse .control_indicator { position: absolute; top: 10px; left: 10px; height: 25px; width: 25px; background: #f0f0f0; border: 2px solid #999999; border-radius: 5px; }
#save-to-warehouse .control_indicator:hover { border-color: #cf1f25; }
#save-to-warehouse input:checked ~ .control_indicator { background: #cf1f25; border-color: #cf1f25; }
#save-to-warehouse input:checked:focus ~ .control_indicator { background: #cf1f25; border-color: #cf1f25; }
#save-to-warehouse .control_indicator:after { box-sizing: unset; content: ''; position: absolute; display: none; }
#save-to-warehouse input:checked ~ .control_indicator:after { display: block; }
#save-to-warehouse .control_indicator:after { left: 6px; top: 1px; width: 6px; height: 12px; border: solid #ffffff; border-width: 0 3px 3px 0; transform: rotate(45deg); }
#save-to-warehouse label span { margin-left: 30px; }
.cart-vw-note { font-size: 14px; font-weight: normal; margin: 10px 0 0 0; border: 2px solid #cf1f25; border-radius: 5px; padding: 5px 10px; }
