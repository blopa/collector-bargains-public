67px) {nav .menu > li {border-top-color: #e3e3e3;}}html.no-js .sf-animation, .mobile-browser .sf-animation, .apple-mobile-browser .sf-animation, .sf-animation[data-animation="none"] {
				opacity: 1!important;left: auto!important;right: auto!important;bottom: auto!important;-webkit-transform: scale(1)!important;-o-transform: scale(1)!important;-moz-transform: scale(1)!important;transform: scale(1)!important;}html.no-js .sf-animation.image-banner-content, .mobile-browser .sf-animation.image-banner-content, .apple-mobile-browser .sf-animation.image-banner-content {
				bottom: 50%!important;}.mobile-browser .product-grid .product {opacity: 1!important;}
/*========== User Custom CSS Styles ==========*/
select, textarea, .woocommerce form .form-row input.input-text, .woocommerce .coupon input.input-text, .woocommerce-cart table.cart td.actions .coupon .input-text { border-width: 1px; }
.select2-container .select2-choice { border-bottom-width: 1px !important; }
/*  .select2-container { width: 100% !important; } */
::placeholder { color: #aaaaaa !important; }
::-ms-input-placeholder { color: #aaaaaa !important; }
p a { color: #222; border-bottom: 1px dotted #222; }
p a:hover { border-color: #cf1f25; }
.vc_btn3.vc_btn3-color-grey, .vc_btn3.vc_btn3-color-grey.vc_btn3-style-flat { background-color: #e3e3e3; }
#back-to-top { left: 10px !important; }

/* Round and unify all buttons */
button, a.button, a.vc_btn3, .bag-buttons a, input.button, input.submit, a.sf-button, .yith-wcwl-add-to-wishlist a, .product-actions .add-to-cart-wrap > a, .product-navigation div, nav.woocommerce-pagination ul li a, nav.woocommerce-pagination ul li a:hover, nav.woocommerce-pagination ul li span.current, #back-to-top { border-radius: 50px !important; text-transform: uppercase; font-weight: bold !important; letter-spacing: 1px; }
.round-img img { border-radius: 10px; box-shadow: 0 5px 10px 0 rgba(0,0,0,.1), 0 2px 4px 0 rgba(0,0,0,.05); }
.home_slider { background: #fff; box-shadow: 0 5px 10px 0 rgba(0,0,0,.1), 0 2px 4px 0 rgba(0,0,0,.05); border-radius: 10px; }
.rev_slider li.tp-revslider-slidesli { border-radius: 10px; }
.woocommerce .quantity input.qty, #jckqv .quantity .qty { border-top-left-radius: 5px; border-bottom-left-radius: 5px; }
@media only screen and (max-width: 991px) {
.woocommerce .quantity input.qty { border-top-right-radius: 5px; border-bottom-right-radius: 5px; }
}
@media only screen and (min-width: 479px) {
.woocommerce .cart_item .quantity input.qty { border-top-right-radius: 0; border-bottom-right-radius: 0; }
}
.qty-plus { border-top-right-radius: 5px; }
.qty-minus { border-bottom-right-radius: 5px; }
li.product.product-display-standard:hover { border-radius: 5px; }

input[type="text"], input[type="email"], input[type="password"], textarea, select, .wpcf7 input[type="text"], .wpcf7 input[type="email"], .wpcf7 textarea, .wpcf7 select, .ginput_container input[type="text"], .ginput_container input[type="email"], .ginput_container textarea, .ginput_container select, .mymail-form input[type="text"], .mymail-form input[type="email"], .mymail-form textarea, .mymail-form select, input[type="date"], input[type="tel"], input[type="number"] { border-bottom-width: 1px; }
.woocommerce-store-notice, p.demo_store { position: fixed; top: initial !important; bottom: 0; min-height: 80px; padding: 5px; background-color: rgba(0,0,0,.85); }

.ubermenu .ubermenu-item .ubermenu-submenu-drop { box-shadow: 0 5px 10px 0 rgba(0,0,0,.1), 0 2px 4px 0 rgba(0,0,0,.05); }
.ubermenu .ubermenu-item-level-0 .ubermenu-target-text { font-weight: 500; }
.ubermenu .ubermenu-item-level-0 a.ubermenu-item-layout-text_only { padding-left: 5px; padding-right: 18px; }
.ubermenu .mainmenu-items a img { margin: 10px 8px; }
.ubermenu .navbadge-dontmiss { margin-top: -5px; }
.ubermenu .ubermenu-target { padding: 10px; }
.ubermenu-sub-indicators .ubermenu-has-submenu-drop>.ubermenu-target>.ubermenu-sub-indicator { right: 6px; margin-top: -6px; font-size: 14px; }
.ubermenu .ubermenu-submenu .ubermenu-submenu-type-flyout { min-width: 200px; }
#menu-item-3789 ul li a.ubermenu-item-layout-text_only { padding: 15px 10px; font-size: 16px; }

.vc_row { margin-left: 0; margin-right: 0; }
.header-overlay .header-wrap, .header-standard-overlay .header-wrap { position: inherit; }
#top-bar { border: 0; }
#top-bar { background: #f00; }
#top-bar .container .tb-left { text-align: center; width: 100%; }
#top-bar .tb-text { color: #fff; font-size: 14px; }
#logo { padding-top: 10px; padding-left: 5px; }
#logo.has-img a > img { padding: 0; }
.header-wrap { background: url(https://hobbyfrontline.com/wp-content/uploads/2024/04/header_bg_rgrx782v2.jpg) #cf1f25 center top no-repeat !important; }
#main-nav { background-color: transparent; }
#main-nav-sticky-wrapper .sticky-header { background: transparent; }
#main-nav-sticky-wrapper.is-sticky .sticky-header { background: rgba(207,31,37,.95); }
#main-nav-sticky-wrapper .menu-item-1309 { display: none; }
#main-nav-sticky-wrapper.is-sticky .menu-item-1309 { display: list-item; }
#header-section #main-nav { border-top: 0; /*box-shadow: 0 5px 10px 0 rgba(0,0,0,.1), 0 2px 4px 0 rgba(0,0,0,.05) !important;*/ box-shadow: none; }
#mobile-header { padding: 10px; border-bottom: 0; box-shadow: 0 3px 15px rgba(0,0,0,.25); height: 67px; }
#mobile-logo.has-img img { max-width: 100% !important; max-height: 50px; }
.mobile-header-opts { margin-top: -5px; }
.shopping-bag-item > a > span.num-items { left: 2px; width: 20px; text-align: center; }
.is-sticky .shopping-bag-item > a > span.num-items { left: 12px; width: 20px; text-align: center; }
@media only screen and (max-width: 991px) {
.is-sticky .shopping-bag-item > a > span.num-items { left: 2px }
}
.bag-header, .bag-product, .bag-empty, .wishlist-empty { border-bottom-width: 1px; border-color: #bb0000; }
.bag-contents, .shopping-bag, .wishlist-bag { width: 300px; overflow-y: auto; }
.shopping-bag .bag-contents { padding-top: 10px; }
.shopping-bag .bag-product { margin: 0 10px !important; padding: 10px 0; }
.shopping-bag .bag-buttons { padding: 10px 0 20px; }
.wishlist-bag .bag-contents { width: inherit; }
.wishlist-bag .bag-contents>.bag-product:first-child { padding-top: 20px; }
.wishlist-bag .bag-product { margin: 0 10px; padding: 10px 0; }
.wishlist-bag .bag-buttons { margin-bottom: 0; padding: 10px 0 20px; }
.wishlist-bag .pricefrom { color: #fff !important; font-weight: normal; opacity: .7; }
.wishlist-bag .woocommerce-Price-amount { font-weight: normal; opacity: .7; }
.bag-product-title a:hover { color:#ffbbbb; }
.bag-product a.remove:hover, .woocommerce .bag-product a.remove:hover { color:#bb0000 !important; }
#mobile-menu .bag-contents, .shopping-bag { width: auto; }
#mobile-menu .bag-product  { border-color: #333333; }
.mobile-search-form { background: #333333 !important; }
#mobile-menu .admin-link { background: #cf1f25 !important; }
