}
.woocommerce nav.woocommerce-pagination { border-top: 0; padding-top: 0; }
.woocommerce nav.woocommerce-pagination ul li { margin-left: 5px; }
.woocommerce nav.woocommerce-pagination .page-numbers.current { border-color: #ccc !important; }
.woocommerce .load-more-btn  { margin: 20px auto; border: 2px solid #e3e3e3; }
.woocommerce .load-more-btn:hover  { border: 2px solid #cf1f25; }
.woocommerce-shop-page #infscr-loading { margin: 37px auto; }

#comments { margin-bottom: 40px; }
#product-reviews-wrap { display: none; background: #f5f5f5; }

.cross-sells h2 { display: inline-block; font-size: 16px; font-weight: bold; border-bottom: 2px solid #222; padding-bottom: 3px; }

.loopbrand { display: block; font-size: 11px; color: #999999; line-height: normal; margin-top: 2px; }
.loopbrand a { font-weight: 500; padding: 0px 5px; border-right: 1px solid #999999; color: #999999; }
.loopbrand a:hover { color: #cf1f25; }
.loopbrand a:first-child { padding-left: 0; }
.loopbrand a:last-child { border-right: 0; }
.loopsku { display: block; font-size: 10px; color: #999999; line-height: normal; margin-top: 1px; }
.buynow-instock { width: 10px; margin: 0 auto; border-top: 2px solid #5fba7d; }
.woocommerce .products .product.product-layout-list .buynow-instock { margin: 0; }

.woocommerce-price-suffix { font-weight: 400; }
.products .woocommerce-price-suffix { display: none; }
.woocommerce-variation-price .woocommerce-Price-amount { font-weight: bold; font-size: 24px; }
.woocommerce-variation-price .woocommerce-price-suffix { font-size: 14px; font-weight: 500; }
.single-product .product-type-simple .woocommerce-Price-amount { font-weight: bold; font-size: 24px; }
.single-product .product-type-simple .woocommerce-price-suffix { font-size: 14px; font-weight: 500; }

h3.spb-heading { text-transform: none !important; font-weight: bold; }
.product-details .posted_in { display: none !important; }
.woocommerce div.product .woocommerce-tabs ul.tabs li a { white-space: normal; }
a.menu-bars-link span::before { color: #fff; }
.woocommerce div.product form.cart .variations { margin-top: 1em; margin-bottom: 1em; }
.woocommerce div.product form.cart .variations select { padding-bottom: 0; }
.woocommerce .cart .yith-wcwl-add-to-wishlist a { border-color: #222; }
.woocommerce .cart .yith-wcwl-add-to-wishlist a:hover { border-color: #cf1f25; }
.woocommerce div.product form.cart .button[data-default_icon="sf-icon-add-to-cart"]:not(.wc-variation-selection-needed):not(.product_type_simple):before { content: '\e602'; font-family: 'si-shop-three'!important; margin-right: 10px; font-size: 24px; font-weight: normal; vertical-align: -4px; }
.woocommerce form.cart button.add_to_cart_button, .woocommerce .single_add_to_cart_button.button.alt { background-color: #cf1f25 !important; color: #fff !important; border-color: #cf1f25 !important; }
.woocommerce form.cart button.add_to_cart_button:hover, .woocommerce .single_add_to_cart_button.button.alt:hover { color: #fff !important; background-color: #e31f26 !important; border-color: #e31f26 !important; }
.woocommerce .single_add_to_cart_button.button.alt.wc-variation-is-unavailable { opacity: .5; cursor: not-allowed; }
.woocommerce form.cart button.single_add_to_cart_button i { display: none; }
@media only screen and (min-width: 321px) and (max-width: 959px) {
.woocommerce div.product form.cart div.quantity { width: 16%; max-width: 76px; float: left !important; }
.woocommerce .summary .quantity input.qty { padding-right: 28px; }
.woocommerce div.product form.cart .button { float: left; width: calc(100% - 16% - 76px); margin: 0 7px; }
.woocommerce div.product form.cart div.quantity.hidden + .button {width: calc(100% - 69px); margin-left: 0; }
.woocommerce form.cart .yith-wcwl-add-to-wishlist { width: 62px; margin-top: 0; }
}
@media only screen and (max-width: 320px) {
.woocommerce form.cart .yith-wcwl-add-to-wishlist { width: 100%; text-align: center; margin-top: 10px; }
.woocommerce div.product form.cart div.quantity { margin-bottom: 10px !important; }
.woocommerce p.form-submit, p.form-submit input.submit { width: 100%; }
}

/* Cart page */
.woocommerce-cart-form { margin-top: -5px; }
.woocommerce-cart-form .row { margin: 0; }
.cart-items-wrap { width: 70%; background: #fff; box-shadow: 0 5px 10px 0 rgba(0,0,0,.1), 0 2px 4px 0 rgba(0,0,0,.05); border-radius: 10px; padding: 10px; margin-bottom: 10px; }
table { line-height: 1.5; }
.woocommerce h3.bag-summary, .woocommerce h3.bag-totals, .woocommerce .woocommerce-billing-fields h3 { font-weight: bold; text-transform: capitalize; margin-top: 0; }
.woocommerce h3.bag-summary span { font-weight: normal; }
.woocommerce .cart_totals table tr.shipping td { padding-bottom: 0; }
@media (min-width: 992px) {
.cart-totals-wrap { width: calc(30% - 10px); margin-left: 10px; }
}
.woocommerce .cart-collaterals { border-top: 1px solid #ccc; margin-top: 20px; margin-bottom: 0; padding-top: 0; }
.woocommerce table.shop_table tr td.actions { padding: 20px 0 20px 0; }
@media only screen and (max-width: 991px) {
.cart-items-wrap { width: 100%; }
.woocommerce .cart_item .quantity .qty-adjust { position: relative; left: -2px; }
.woocommerce-page table.cart td.actions .coupon { margin-bottom: 10px; }
.woocommerce .cart button[name="update_cart"] { width: 100% !important; margin-top: 0; }
}
.woocommerce table.shop_table, .woocommerce-page table.shop_table { border-top: 2px solid #222; border-bottom: 0; margin-bottom: 10px; }
.woocommerce table.shop_table tr td, .woocommerce-page table.shop_table tr td { padding: 10px 0; vertical-align: middle; }
.woocommerce table.shop_table td { border-top-width: 1px; }

.woocommerce table.shop_table.cart td.product-name, .woocommerce table.shop_table tr td.product-price, .woocommerce table.shop_table tr td.product-subtotal { padding: 10px 2px; }
.woocommerce td.product-name dl.variation dt, .woocommerce td.product-name dl.variation dd p { font-size: 11px; line-height: normal; padding-top: 0; }
.woocommerce td.product-name dl.variation { margin-top: 5px; }
.woocommerce table.shop_table tr td.product-remove .remove { width: 30px; font-size: 20px; }
.woocommerce .cart_totals table tr.order-total { border-top-width: 1px; }
.woocommerce .cart_totals p { line-height: 16px; }
.cart-totals-wrap { background: #fff; box-shadow: 0 5px 10px 0 rgba(0,0,0,.1), 0 2px 4px 0 rgba(0,0,0,.05); border-radius: 10px; padding: 10px; }
.cart-totals-wrap .includes_tax::before { content: ''; display: block; }
.cart-totals-wrap .includes_tax { line-height: 1.4rem; }
.cart-totals-wrap .includes_tax span { font-size: 1.4rem !important; }
.woocommerce input[name="empty_cart"] { padding: 14px 16px; border: 2px solid #e3e3e3; }
.woocommerce input[name="empty_cart"]:hover { border-color: #cf1f25; }
.woocommerce .cart_item .quantity { max-width: 50px; margin-right: 0 !important; }
.woocommerce .cart_item .quantity .qty-plus, .woocommerce .cart_item .quantity .qty-minus { width: 25px; }
.woocommerce .cart_totals table tr.shipping th { vertical-align: top; }
.woocommerce-cart table.cart td.actions .coupon .input-text { margin-right: 10px; }
.woocommerce tr.cart-subtotal { border-top-color: #222 !important; }
.woocommerce ul#shipping_method .amount { font-weight: normal; }
.woocommerce .cart_totals table tr.order-total td span { font-weight: inherit; }
.woocommerce table.shop_table td small { font-size: smaller; }
.woocommerce-cart .wc-proceed-to-checkout { padding: 20px 0 0 0; }
.woocommerce-cart .coupon label { display: none; }

/* Mobile cart slideout */
@-moz-document url-prefix() {
.mobile-header-opts.opts-left .num-items { right: 7px !important; }
}
#mobile-cart-wrap .bag-product, .bag-total, .bag-buttons  { margin: 0 10px; }
#mobile-cart-wrap { background-color: #cf1f25; box-shadow: rgba(0,0,0,.25) 5px 0 15px; }
#mobile-cart-wrap .bag-product { border-color: #bb0000; }
#mobile-cart-wrap .bag-buttons  { margin-bottom: 20px; }

/* Mobile menu slideout */
#mobile-menu-wrap { box-shadow: rgba(0,0,0,.25) -5px 0 15px; }
#mobile-menu-wrap.menu-is-right { right: -295px; }
#mobile-menu ul li.shopping-bag-item { display: none; }

/* Checkout page */
#account_password_field label, .woocommerce-password-hint { line-height: 1.5em !important; }
.woocommerce form.checkout_coupon, .woocommerce form.login, .woocommerce form.register { border-color: #ccc; }
.woocommerce form.checkout_coupon { padding: 20px 0; }
.woocommerce form.checkout_coupon p { margin-bottom: 5px; }
.woocommerce-checkout form.checkout { margin: 0; }
#customer_details { width: calc(50% - 5px); margin-right: 5px; border-radius: 10px; box-shadow: 0 5px 10px 0 rgba(0,0,0,.1), 0 2px 4px 0 rgba(0,0,0,.05); background: #fff; padding: 10px; }
@media only screen and (min-width: 480px) {
#customer_details label[for="billing_company"], #customer_details label[for="shipping_company"] { line-height: 1.5em !important; }
}
#customer_details .form-row { margin-bottom: 10px !important; }
#customer_details .form-row label { font-weight: bold !important; font-size: 95%; }
#review-order { width: calc(50% - 5px); margin-left: 5px; border-radius: 10px; box-shadow: 0 5px 10px 0 rgba(0,0,0,.1), 0 2px 4px 0 rgba(0,0,0,.05); background: #fff; padding: 10px; }
#review-order .woocommerce-checkout-review-order { border: 0; padding: 0; }
#order_review_heading { margin-top: 0; }
#order_review table.shop_table { border-bottom: 0 !important; }
#order_review .woocommerce-checkout-review-order-table th.product-name, #order_review .woocommerce-checkout-review-order-table td.product-name { display: inline-block; width: 80%; max-width: none; padding: 10px 0 !important; }
#order_review .woocommerce-checkout-review-order-table th.product-total, #order_review .woocommerce-checkout-review-order-table td.product-total { display: inline-block; width: 19.1%; max-width: none; padding: 10px 0 !important; vertical-align: top; }
#order_review .woocommerce-checkout-review-order-table td.product-name dl.variation { margin-top: 5px; }
#order_review .woocommerce-checkout-review-order-table tr.cart-subtotal th { display: inline-block; width: 80%; max-width: none; padding: 10px 0 !important; }
#order_review .woocommerce-checkout-review-order-table tr.cart-subtotal td { display: inline-block; width: calc(20% - 4px); padding: 10px 0; padding: 10px 0 !important; }
#order_review .woocommerce-checkout-review-order-table tr.cart-discount th { display: inline-block; width: 50%; max-width: none; padding: 10px 0 !important; }
#order_review .woocommerce-checkout-review-order-table tr.cart-discount td { display: inline-block; width: 50%; padding: 10px 0; padding: 10px 0 !important; }
#order_review .woocommerce-checkout-review-order-table tr.shipping th { display: inline-block; width: calc(20% - 4px); max-width: none; padding: 10px 0 !important; vertical-align: top; }
#order_review .woocommerce-checkout-review-order-table tr.shipping td { display: inline-block; width: 80%; padding: 10px 0 !important; }
#order_review .woocommerce-checkout-review-order-table tr.fee th { display: inline-block; width: 80%; max-width: none; padding: 10px 0 !important; }
#order_review .woocommerce-checkout-review-order-table tr.fee td { display: inline-block; width: calc(20% - 4px); padding: 10px 0; padding: 10px 0 !important; }
#order_review .woocommerce-checkout-review-order-table tr.order-total th { display: inline-block; width: calc(20% - 4px); max-width: none; padding: 10px 0 !important; vertical-align: top; }
#order_review .woocommerce-checkout-review-order-table tr.order-total td { display: inline-block; width: 80%; padding: 10px 0 !important; vertical-align: top; }
.cart-totals-wrap a.continue-shopping { text-align: center; display: block; margin: 10px 0 !important; }
a.continue-shopping { display: none; }
@media only screen and (max-width: 991px) {
#customer_details { width: 100%; }
#review-order { width: 100%; margin-top: 10px; margin-left: 0; }  
}
.woocommerce .woocommerce-billing-fields h3 { border-bottom: 2px solid #222; padding-bottom: 15px; }
#review-order .order-total .woocommerce-Price-amount { font-size: 2.5rem; line-height: normal; display: block; }
#review-order .order-total .includes_tax span { font-size: 1.4rem !important; }
#review-order .order-total .includes_tax .woocommerce-Price-amount { display: inline; }
.woocommerce table.shop_table tfoot th, .woocommerce table.shop_table tfoot td, .woocommerce table.shop_table tbody th { border-top-width: 1px; font-weight: 400; }
table.customer_details td { border-top: 1px solid #e3e3e3 !important; }
.woocommerce table.shop_table tbody:first-child tr:first-child td { border-top: 0 !important; }
.review-order-wrap #payment { margin: 0; padding: 0; border-color: #222; }
#review-order tfoot th { font-size: inherit; }
#wc-stripe-payment-request-wrapper { padding-top: 0 !important; }
#wc-stripe-payment-request-button-separator { margin-top: 10px !important; margin-bottom: 10px; }
.woocommerce #payment div.payment_box, #add_payment_method #payment div.payment_box { background: #e3e3e3; margin: 5px 0 0 0; border-radius: 5px; }
#add_payment_method #payment ul.payment_methods li input { margin: 0; }
.woocommerce #payment ul.payment_methods li { margin-bottom: 10px; }
.woocommerce #payment ul.payment_methods li.payment_method_stripe label[for=payment_method_stripe] { padding-left:10px; }
.woocommerce #payment ul.payment_methods li.payment_method_paypal label { padding-left:10px; }
.woocommerce #payment ul.payment_methods li.payment_method_ppcp-gateway label { padding-left:10px; }
form#order_review #payment_method_stripe, .woocommerce #payment ul.payment_methods li input { margin: 0 0 0 5px; }
#add_payment_method #payment div.payment_box:before, .woocommerce-cart #payment div.payment_box::before, .woocommerce-checkout #payment div.payment_box::before { top: -.5em; border-bottom-color: #e3e3e3; left: 10px; }
.woocommerce #payment div.payment_box p { margin-bottom: 0; }
.woocommerce #payment div.form-row.place-order { padding: 0; }
.woocommerce .button.checkout-button:hover, .review-order-wrap #payment #place_order { margin-bottom: 0; }
#place_order { border: none; }
#stripe-payment-data > button { height: 60px !important; line-height: 60px; background: #cf1f25; color: #fff; padding: 0 30px; font-size: 100%; border: none; }
@media only screen and (max-width: 479px) {
#stripe-payment-data > button { width: 100%; }
}
#stripe-payment-data fieldset { border: none; }
.wc-gateway-ppec-cancel { margin-top: 20px; display: inline-block; text-align: center; width: 100%; }

.carousel-wrap a.carousel-prev, .carousel-wrap a.carousel-next { opacity: 1; }

.home_pb_section_title h4 { color: #fff; }

.vc_column_container > .vc_column-inner, .vc_row-has-fill > .vc_column_container > .vc_column-inner { padding: 0 !important; }
.wpb_content_element { margin: 0; }
.vc_separator h4 { font-size: 16px; }
.vc_separator .vc_sep_holder { width: auto !important; }
.vc_separator .vc_sep_holder .vc_sep_line { top: -2px; }

.woocommerce .woocommerce-info, .woocommerce-page .woocommerce-info, .woocommerce .woocommerce-message, .woocommerce-page .woocommerce-message, .woocommerce .woocommerce-error, .woocommerce-page .woocommerce-error { margin-top: 0 !important; margin-bottom: 20px !important; border-radius: 5px; }
.woocommerce .woocommerce-message, .woocommerce-page .woocommerce-message { border-color: #add; }
.woocommerce .woocommerce-error a.button, .woocommerce-page .woocommerce-message a.button { font-size: 12px; padding: 10px 20px; float: right; margin: 0 0 5px 10px; border: 2px solid #e3e3e3; background-color: #fff; }
.woocommerce .woocommerce-error a.button:hover, .woocommerce-page .woocommerce-message a.button:hover { border-color: #cf1f25; }
.woocommerce .product-main>.woocommerce-message { margin-top: 10px !important; }
.woocommerce .woocommerce-error { margin-top: 10px !important; background: #fff0f0 !important; border-color: #cf1f25; }
.woocommerce .woocommerce-error a.error-link { color: #cf1f25; font-weight: 500; }
.woocommerce-page .woocommerce-message a.button:hover { border-color: #cf1f25; }
.woocommerce .woocommerce-NoticeGroup-checkout { margin-left: 5px; margin-right: 5px; }
.woocommerce .woocommerce-NoticeGroup-checkout .woocommerce-error { background: #fff0f0 !important; border-color: #cf1f25; }
.woocommerce-checkout .woocommerce>form.login { margin-top: 0; border-radius: 0; border-left: 0; border-right: 0; }
.woocommerce-checkout .login input[type="submit"] { border: 2px solid #e3e3e3; }
.woocommerce .woocommerce-order p.woocommerce-thankyou-order-received { font-size: 20px; line-height: 28px; }

.flexslider li a.zoom { top: auto; bottom: 15px; }

/* Badges */
.produ1ct-img-area .badge-wrap { width: 0; height: 0; right: auto; left: 0; }
.yith-wcbm-badge-custom { border-radius: 5px; }
.shopping-bag .yith-wcbm-badge { display: none; }
.wishlist-bag .yith-wcbm-badge { display: none; }
.yith-wcbm-badge-image img, .yith-wcbm-badge-image:hover img { transform: none !important; }
.product .yith-wcbm-badge-577 { width: 50px !important; }
.products .product.product-layout-standard .yith-wcbm-badge-577 { width: 40px !important; }
.products .product.product-layout-list .yith-wcbm-badge-577 { width: 25px !important; }
.products .product.product-layout-grid .yith-wcbm-badge-577 { width: 30px !important; }
.woocommerce .products .product figure .badge-wrap { top: calc(50% - 25px); right: calc(50% - 53px); }
.woocommerce .out-of-stock-badge:before, .woocommerce .out-of-stock-badge:after { display: none; }
.woocommerce .out-of-stock-badge { background-color: #000; color: #fff; font-size: 100%; line-height: 28px; border-radius: 5px; }
.yith-wcbm-advanced-display-percentage { filter: drop-shadow(-1px 1px #fff); }
.yith-wcbm-advanced-display-percentage .yith-wcbm-shape1 { border-radius: 3px; }
.yith-wcbm-advanced-display-percentage .yith-wcbm-shape1:before { bottom: -5px; }
@media only screen and (max-width: 767px) {
.woocommerce .out-of-stock-badge { display: block; }
}
.woocommerce .products .product figure .badge-wrap>span { opacity: .6; }

/* Quickview */
#jckqv { border-radius: 10px; animation: fade .3s; }
#jckqv .iconic-woothumbs-all-images-wrap { width: 55%; margin: -30px 0 0 -30px; }
#jckqv .single_variation_wrap { margin-top: 0; }
#jckqv .quantity .qty, #jckqv .quantity .qty-adjust a { border-color: #e3e3e3; }
#jckqv h1 { line-height: 32px !important; letter-spacing: 0 !important; border-bottom-width: 1px; }
#jckqv .cart { margin: 0 0 25px 0; }
#jckqv .price ins { margin-right: 5px; }
#jckqv .product_meta { margin: 0; }
#jckqv p { margin-bottom: 0; }

/* Account page */
.yith-wcmap .user-profile { display: block; text-align: center; margin-bottom: 10px; background: #e3e3e3; border-radius: 10px; padding: 15px 10px 0 10px; }
.yith-wcmap .user-profile .user-avatar { margin: 10px 0; display: none; }
#my-account-menu.layout-no-borders { padding: 0; }
#my-account-menu.position-vertical-left { margin-right: 0; }
#my-account-menu { width: 20%; }
#my-account-menu ~ .woocommerce-MyAccount-content { width: 80%; }
#my-account-menu .user-image img { border-radius: 50%; }
#my-account-menu .user-info { padding-bottom: 10px; }
#my-account-menu .logout { margin: 15px 0 5px 0; }
#my-account-menu .logout a, #my-account-menu-tab .logout a { color: #222; background: none; border: 2px solid #ccc; font-weight: bold; font-size: 12px; border-radius: 50px; }
#my-account-menu .logout a:hover, #my-account-menu-tab .logout a:hover { color: #cf1f25; background: none; border-color: #cf1f25; }
#my-account-menu .myaccount-menu:before { padding: 0; }
#my-account-menu.position-left { padding-right: 10px; }
#my-account-menu.position-left .myaccount-menu:before { border: 0; }
#my-account-menu .myaccount-menu { margin: 0; }
#my-account-menu .myaccount-menu li a { font-size: 14px; line-height: normal; letter-spacing: 1px; background: #f0f0f0; padding: 10px 5px 10px 10px; border-color: #e3e3e3; border-left: 0 !important; border-right: 0 !important; }
#my-account-menu .myaccount-menu li a:hover, #my-account-menu .myaccount-menu li.active a { color: #cf1f25; border-right: 0 !important; }
#my-account-menu .myaccount-menu li > a > .fa { display: inline-block; width: 20px; text-align: center; float: left; line-height: 20px; }
#my-account-menu .myaccount-menu:after { display: none; }
#my-account-menu .myaccount-menu li > a.yith-preback-orders { display: none; }
#my-account-menu .myaccount-menu li a, #my-account-menu .myaccount-menu li.active a, #my-account-menu .myaccount-menu li a:hover { display: block; text-align: left; background: #fff; padding: 10px 5px 10px 10px; border: 2px solid #e3e3e3 !important; margin: 5px 0; border-radius: 10px; }
#my-account-menu .myaccount-menu li a:hover { border-color: #cf1f25 !important ; box-shadow: 0 5px 10px 0 rgba(0, 0, 0, .1), 0 2px 4px 0 rgba(0, 0, 0, .05); }
#my-account-menu .myaccount-menu li.active a { border-color: #cf1f25 !important; background-color: #cf1f25; color: #fff; box-shadow: 0 5px 10px 0 rgba(0, 0, 0, .1), 0 2px 4px 0 rgba(0, 0, 0, .05); }
@media only screen and (max-width: 768px) {
#my-account-menu, .woocommerce-MyAccount-content { width: 100% !important; }
#my-account-menu.position-left { padding: 0; }
#my-account-menu .myaccount-menu { margin-bottom: 10px; }
#my-account-menu .myaccount-menu li a, #my-account-menu .myaccount-menu li.active a, #my-account-menu .myaccount-menu li a:hover { display: block; text-align: left; letter-spacing: 0.5px; background: #fff; padding: 10px 5px 10px 10px; border: 2px solid #e3e3e3 !important; margin: 2px; border-radius: 10px; }
#my-account-menu .myaccount-menu li a:hover { border-color: #cf1f25 !important ; }
#my-account-menu .myaccount-menu li.active a { border-color: #cf1f25 !important; background-color: #cf1f25; color: #fff; box-shadow: 0 5px 10px 0 rgba(0, 0, 0, .1), 0 2px 4px 0 rgba(0, 0, 0, .05); }
#my-account-menu .myaccount-menu li a span.item-icon { margin-right: 0; }
#my-account-menu .myaccount-menu li { width: 50%; float: left}
#my-account-menu.position-vertical-left ~ .woocommerce-MyAccount-content { float: right !important; margin-top: 10px; }
}
