/* Product layout sizes */
.woocommerce ul.products li.product.product-layout-grid { width: calc((100% - 100px) / 5); margin: 10px !important; }
.woocommerce ul.products li.product.product-layout-standard { width: calc((100% - 80px) / 4); margin: 10px !important; }
.woocommerce ul.products li.product.product.product-layout-list, .woocommerce ul.products li.product.product.product-layout-solo { width: calc(100% - 20px) !important; margin: 10px !important; }
@media only screen and (max-width: 1199px) {
.woocommerce ul.products li.product.product-layout-grid { width: calc((100% - 50px) / 5); margin: 5px !important; }
.woocommerce ul.products li.product.product-layout-standard { width: calc((100% - 40px) / 4); margin: 5px !important; }
.woocommerce ul.products li.product.product.product-layout-list, .woocommerce ul.products li.product.product.product-layout-solo { width: calc(100% - 10px) !important; margin: 5px !important; }
}
@media only screen and (max-width: 765px) {
.woocommerce ul.products li.product.product-layout-grid { width: calc((100% - 20px) / 2) !important; margin: 5px !important; }
.woocommerce ul.products li.product.product.product-layout-list, .woocommerce ul.products li.product.product.product-layout-solo { width: calc(100% - 10px) !important; margin: 5px !important; }
}

