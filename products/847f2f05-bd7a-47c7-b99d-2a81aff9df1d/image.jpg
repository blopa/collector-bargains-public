.vw_switch { position: relative; display: inline-block; width: 34px; height: 20px; margin-left: 5px; }
.vw_switch input { opacity: 0; width: 0; height: 0; }
.vw_slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #ccc; -webkit-transition: .3s; transition: .3s; }
.vw_slider:before { position: absolute; content: ""; height: 16px; width: 16px; left: 2px; bottom: 2px; background-color: white; -webkit-transition: .3s; transition: .3s; }
input:checked + .vw_slider { background-color: #cf1f25; }
input:fo1cus + .vw_slider { box-shadow: 0 0 1px #2196F3; }
input:checked + .vw_slider:before { -webkit-transform: translateX(14px); -ms-transform: translateX(14px); transform: translateX(14px); }
.vw_slider.vw_round { border-radius: 10px; }
.vw_slider.vw_round:before { border-radius: 50%; }

